index 0000000..8dfc949
--- /dev/null
+++ b/client/src/components/dashboard/AnnouncementBoard.tsx
@@ -0,0 +1,305 @@
+import {
+  Megaphone,
+  Plus,
+  Send,
+  Trash2,
+  Eye,
+  EyeOff,
+} from "lucide-react";
+import { useState, type FormEvent } from "react";
+import { toast } from "sonner";
+import { getErrorMessage } from "../../services/api";
+import { announcementService } from "../../services/announcement.service";
+import { useAuthStore } from "../../store/auth.store";
+import type { Announcement, AnnouncementTone } from "../../types";
+import { cn } from "../../utils/cn";
+import { Button } from "../ui/Button";
+import { Input } from "../ui/Input";
+import { Textarea } from "../ui/Textarea";
+
+const toneOptions: { value: AnnouncementTone; label: string }[] = [
+  { value: "info", label: "Update" },
+  { value: "success", label: "Good news" },
+  { value: "warning", label: "Important" },
+];
+
+function toneClass(tone: AnnouncementTone) {
+  if (tone === "success") {
+    return "border-emerald-500/25 bg-emerald-500/10 text-emerald-700 dark:text-emerald-300";
+  }
+
+  if (tone === "warning") {
+    return "border-amber-500/25 bg-amber-500/10 text-amber-700 dark:text-amber-300";
+  }
+
+  return "border-sky-500/25 bg-sky-500/10 text-sky-700 dark:text-sky-300";
+}
+
+function toneLabel(tone: AnnouncementTone) {
+  return toneOptions.find((option) => option.value === tone)?.label || "Update";
+}
+
+function formatDate(value: string) {
+  const date = new Date(value);
+
+  if (Number.isNaN(date.getTime())) return "";
+
+  return date.toLocaleDateString("en-US", {
+    month: "short",
+    day: "numeric",
+    year: "numeric",
+  });
+}
+
+function authorName(author: Announcement["createdBy"]) {
+  if (typeof author === "object" && author?.fullName) return author.fullName;
+  return "Mono team";
+}
+
+export function AnnouncementBoard({
+  announcements,
+  onChanged,
+}: {
+  announcements: Announcement[];
+  onChanged: () => Promise<void> | void;
+}) {
+  const user = useAuthStore((state) => state.user);
+  const canManage = user?.role === "admin" || user?.role === "manager";
+  const [showForm, setShowForm] = useState(false);
+  const [title, setTitle] = useState("");
+  const [message, setMessage] = useState("");
+  const [tone, setTone] = useState<AnnouncementTone>("info");
+  const [submitting, setSubmitting] = useState(false);
+  const [updatingId, setUpdatingId] = useState<string | null>(null);
+
+  async function refresh() {
+    await onChanged();
+  }
+
+  async function createAnnouncement(event: FormEvent<HTMLFormElement>) {
+    event.preventDefault();
+
+    if (!title.trim() || !message.trim()) {
+      toast.error("Please add a title and message");
+      return;
+    }
+
+    try {
+      setSubmitting(true);
+      await announcementService.create({
+        title,
+        message,
+        tone,
+        active: true,
+      });
+      toast.success("Announcement published");
+      setTitle("");
+      setMessage("");
+      setTone("info");
+      setShowForm(false);
+      await refresh();
+    } catch (error) {
+      toast.error(getErrorMessage(error));
+    } finally {
+      setSubmitting(false);
+    }
+  }
+
+  async function toggleAnnouncement(announcement: Announcement) {
+    try {
+      setUpdatingId(announcement._id);
+      await announcementService.update(announcement._id, {
+        active: !announcement.active,
+      });
+      toast.success(
+        announcement.active ? "Announcement hidden" : "Announcement restored"
+      );
+      await refresh();
+    } catch (error) {
+      toast.error(getErrorMessage(error));
+    } finally {
+      setUpdatingId(null);
+    }
+  }
+
+  async function deleteAnnouncement(announcementId: string) {
+    const confirmed = window.confirm(
+      "Delete this announcement? This cannot be undone."
+    );
+
+    if (!confirmed) return;
+
+    try {
+      setUpdatingId(announcementId);
+      await announcementService.remove(announcementId);
+      toast.success("Announcement deleted");
+      await refresh();
+    } catch (error) {
+      toast.error(getErrorMessage(error));
+    } finally {
+      setUpdatingId(null);
+    }
+  }
+
+  return (
+    <section className="w-full max-w-full overflow-hidden rounded-3xl border border-[var(--border)] bg-[var(--surface)] p-5">
+      <div className="flex min-w-0 flex-col justify-between gap-4 sm:flex-row sm:items-start">
+        <div className="min-w-0">
+          <div className="flex min-w-0 items-center gap-2">
+            <span className="rounded-2xl bg-[var(--surface-soft)] p-2 text-[var(--muted)]">
+              <Megaphone className="h-4 w-4" />
+            </span>
+            <p className="text-xs font-semibold uppercase tracking-[0.18em] text-[var(--muted)]">
+              Announcements
+            </p>
+          </div>
+
+          <h2 className="mt-3 break-words text-xl font-semibold tracking-tight">
+            Mono updates board
+          </h2>
+          <p className="mt-1 max-w-2xl text-sm leading-6 text-[var(--muted)]">
+            Product updates, bug fixes, and important notes from the Mono team.
+          </p>
+        </div>
+
+        {canManage && (
+          <Button
+            type="button"
+            variant={showForm ? "secondary" : "primary"}
+            size="sm"
+            onClick={() => setShowForm((value) => !value)}
+            className="shrink-0"
+          >
+            <Plus className="h-4 w-4" />
+            {showForm ? "Close" : "New update"}
+          </Button>
+        )}
+      </div>
+
+      {canManage && showForm && (
+        <form
+          onSubmit={createAnnouncement}
+          className="mt-5 rounded-3xl border border-[var(--border)] bg-[var(--background)] p-4"
+        >
+          <div className="grid gap-3 lg:grid-cols-[1fr_auto]">
+            <Input
+              value={title}
+              onChange={(event) => setTitle(event.target.value)}
+              placeholder="Announcement title"
+              maxLength={120}
+            />
+
+            <select
+              value={tone}
+              onChange={(event) => setTone(event.target.value as AnnouncementTone)}
+              className="h-10 rounded-xl border border-[var(--border)] bg-[var(--surface)] px-3 text-sm text-[var(--text)]"
+            >
+              {toneOptions.map((option) => (
+                <option key={option.value} value={option.value}>
+                  {option.label}
+                </option>
+              ))}
+            </select>
+          </div>
+
+          <Textarea
+            value={message}
+            onChange={(event) => setMessage(event.target.value)}
+            placeholder="Write a short update that every user should see..."
+            maxLength={900}
+            className="mt-3 min-h-24"
+          />
+
+          <div className="mt-3 flex justify-end">
+            <Button type="submit" disabled={submitting}>
+              <Send className="h-4 w-4" />
+              {submitting ? "Publishing..." : "Publish"}
+            </Button>
+          </div>
+        </form>
+      )}
+
+      <div className="mt-5 space-y-3">
+        {announcements.length === 0 ? (
+          <div className="rounded-3xl border border-dashed border-[var(--border)] bg-[var(--background)] p-5 text-sm text-[var(--muted)]">
+            No announcements yet.
+          </div>
+        ) : (
+          announcements.map((announcement) => (
+            <article
+              key={announcement._id}
+              className={cn(
+                "rounded-3xl border border-[var(--border)] bg-[var(--background)] p-4",
+                !announcement.active && "opacity-60"
+              )}
+            >
+              <div className="flex min-w-0 flex-col justify-between gap-3 sm:flex-row sm:items-start">
+                <div className="min-w-0 flex-1">
+                  <div className="flex min-w-0 flex-wrap items-center gap-2">
+                    <span
+                      className={cn(
+                        "rounded-full border px-3 py-1 text-xs font-medium",
+                        toneClass(announcement.tone)
+                      )}
+                    >
+                      {toneLabel(announcement.tone)}
+                    </span>
+
+                    {!announcement.active && canManage && (
+                      <span className="rounded-full border border-[var(--border)] px-3 py-1 text-xs text-[var(--muted)]">
+                        Hidden
+                      </span>
+                    )}
+                  </div>
+
+                  <h3 className="mt-3 break-words text-base font-semibold tracking-tight">
+                    {announcement.title}
+                  </h3>
+
+                  <p className="mt-2 whitespace-pre-wrap break-words text-sm leading-6 text-[var(--muted)]">
+                    {announcement.message}
+                  </p>
+
+                  <p className="mt-3 text-xs text-[var(--muted)]">
+                    Posted by {authorName(announcement.createdBy)} on{" "}
+                    {formatDate(announcement.createdAt)}
+                  </p>
+                </div>
+
+                {canManage && (
+                  <div className="flex shrink-0 flex-wrap gap-2">
+                    <Button
+                      type="button"
+                      variant="secondary"
+                      size="sm"
+                      disabled={updatingId === announcement._id}
+                      onClick={() => toggleAnnouncement(announcement)}
+                    >
+                      {announcement.active ? (
+                        <EyeOff className="h-4 w-4" />
+                      ) : (
+                        <Eye className="h-4 w-4" />
+                      )}
+                      {announcement.active ? "Hide" : "Show"}
+                    </Button>
+
+                    <Button
+                      type="button"
+                      variant="danger"
+                      size="sm"
+                      disabled={updatingId === announcement._id}
+                      onClick={() => deleteAnnouncement(announcement._id)}
+                    >
+                      <Trash2 className="h-4 w-4" />
+                      Delete
+                    </Button>
+                  </div>
+                )}
+              </div>
+            </article>
+          ))
+        )}
+      </div>
+    </section>
+  );
+}
